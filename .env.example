# ─── ZKLease — Environment Variables ─────────────────────────────────────
# Copy to .env and fill in your values.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────

# ── Network ────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Stellar / Soroban ─────────────────────────────────────────────────────
STELLAR_NETWORK=TESTNET
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

SOROBAN_ACCOUNT=zklease-admin
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Deployed contract ID (set after running deploy-contracts.sh)
CONTRACT_ID=

USDC_CONTRACT_ID=CCW67TSZV3SSWZ6YQ6KQKJN7ED5QG2R2ZNZQ2R2ZNZQ2R2ZNZQ2R2ZN

# ── API ────────────────────────────────────────────────────────────────────
API_PORT=4000

# ── Seed Data ──────────────────────────────────────────────────────────────
# Set to "true" to seed sample data on first API start
SEED_ON_START=false
