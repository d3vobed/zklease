{
  "name": "zklease",
  "version": "1.0.0",
  "private": true,
  "description": "ZKLease - Zero-Knowledge Proof for USDC Balance on Stellar",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "setup": "npm install && npm run build",
    "deploy:contracts": "bash scripts/deploy-contracts.sh",
    "deploy:web": "cd apps/web && vercel --prod",
    "deploy:api": "cd apps/api && railway up"
  },
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=18.0.0"
  }
}
